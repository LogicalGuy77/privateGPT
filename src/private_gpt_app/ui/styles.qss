/* Premium Black Theme for Private-GPT */

/* Global Styles */
* {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
}

QMainWindow {
    background-color: #0A0A0A;
}

/* Sidebar */
#sidebar {
    background-color: #1A1A1A;
    border-right: 1px solid #2A2A2A;
}

#sidebarHeader {
    color: #FFFFFF;
    padding: 10px;
}

#newChatButton {
    background-color: #2A2A2A;
    color: #FFFFFF;
    border: 1px solid #3A3A3A;
    border-radius: 8px;
    padding: 10px;
    font-weight: bold;
    font-size: 14px;
}

#newChatButton:hover {
    background-color: #3A3A3A;
    border-color: #4A4A4A;
}

#newChatButton:pressed {
    background-color: #252525;
}

#sessionList {
    background-color: #1A1A1A;
    border: 1px solid #2A2A2A;
    border-radius: 8px;
    color: #CCCCCC;
    padding: 5px;
}

#sessionList::item {
    padding: 12px;
    border-radius: 6px;
    margin: 2px 0px;
}

#sessionList::item:hover {
    background-color: #2A2A2A;
}

#sessionList::item:selected {
    background-color: #3A3A3A;
    color: #FFFFFF;
}

#settingsButton {
    background-color: #2A2A2A;
    color: #FFFFFF;
    border: 1px solid #3A3A3A;
    border-radius: 8px;
    padding: 10px;
    font-weight: bold;
    font-size: 13px;
}

#settingsButton:hover {
    background-color: #3A3A3A;
    border-color: #4A4A4A;
}

#settingsButton:pressed {
    background-color: #252525;
}

#vramLabel {
    color: #4CAF50;
    padding: 5px;
    font-size: 11px;
}

#statusLabel {
    color: #888888;
    padding: 10px;
    font-size: 12px;
}

/* Chat Container */
#chatContainer {
    background-color: #0A0A0A;
}

#chatScrollArea {
    background-color: #0A0A0A;
    border: none;
}

#messagesContainer {
    background-color: #0A0A0A;
}

#welcomeMessage {
    color: #888888;
    font-size: 16px;
    padding: 40px;
}

/* Message Bubbles */
#userBubble {
    background-color: #2563EB;
    border-radius: 12px;
}

#assistantBubble {
    background-color: #1A1A1A;
    border: 1px solid #2A2A2A;
    border-radius: 12px;
}

#roleLabel {
    color: #FFFFFF;
    font-size: 13px;
}

#timestampLabel {
    color: #888888;
    font-size: 11px;
}

#messageText {
    background-color: transparent;
    color: #FFFFFF;
    font-size: 14px;
    line-height: 1.6;
    selection-background-color: #3A3A3A;
}

/* User bubble text - white for better contrast */
#userBubble #messageText {
    color: #FFFFFF;
}

/* Assistant bubble text - light gray */
#assistantBubble #messageText {
    color: #E5E5E5;
}

/* Input Area */
#inputContainer {
    background-color: #1A1A1A;
    border-top: 1px solid #2A2A2A;
}

#messageInput {
    background-color: #0A0A0A;
    border: 2px solid #2A2A2A;
    border-radius: 8px;
    color: #FFFFFF;
    font-size: 14px;
    padding: 12px;
    selection-background-color: #3A3A3A;
}

#messageInput:focus {
    border-color: #2563EB;
}

#modeLabel {
    color: #888888;
    font-size: 12px;
    padding: 5px 10px;
}

#clearButton {
    background-color: #2A2A2A;
    color: #CCCCCC;
    border: 1px solid #3A3A3A;
    border-radius: 6px;
    padding: 8px 16px;
    font-size: 13px;
}

#clearButton:hover {
    background-color: #3A3A3A;
    color: #FFFFFF;
}

#clearButton:pressed {
    background-color: #252525;
}

#sendButton {
    background-color: #2563EB;
    color: #FFFFFF;
    border: none;
    border-radius: 6px;
    padding: 8px 24px;
    font-size: 13px;
    font-weight: bold;
}

#sendButton:hover {
    background-color: #1D4ED8;
}

#sendButton:pressed {
    background-color: #1E40AF;
}

#sendButton:disabled {
    background-color: #374151;
    color: #6B7280;
}

/* Scrollbars */
QScrollBar:vertical {
    background-color: #0A0A0A;
    width: 12px;
    border: none;
}

QScrollBar::handle:vertical {
    background-color: #2A2A2A;
    border-radius: 6px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background-color: #3A3A3A;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}

/* Splitter */
QSplitter::handle {
    background-color: #2A2A2A;
    width: 1px;
}

QSplitter::handle:hover {
    background-color: #3A3A3A;
}

/* Settings Dialog */
QDialog {
    background-color: #0A0A0A;
}

QGroupBox {
    color: #FFFFFF;
    border: 1px solid #2A2A2A;
    border-radius: 8px;
    margin-top: 10px;
    padding-top: 15px;
    font-weight: bold;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 5px 10px;
    color: #FFFFFF;
}

QSlider::groove:horizontal {
    background-color: #2A2A2A;
    height: 6px;
    border-radius: 3px;
}

QSlider::handle:horizontal {
    background-color: #2563EB;
    width: 16px;
    height: 16px;
    margin: -5px 0;
    border-radius: 8px;
}

QSlider::handle:horizontal:hover {
    background-color: #1D4ED8;
}

QComboBox {
    background-color: #1A1A1A;
    color: #FFFFFF;
    border: 1px solid #2A2A2A;
    border-radius: 6px;
    padding: 8px;
}

QComboBox:hover {
    border-color: #3A3A3A;
}

QComboBox::drop-down {
    border: none;
}

QComboBox QAbstractItemView {
    background-color: #1A1A1A;
    color: #FFFFFF;
    selection-background-color: #2563EB;
}

